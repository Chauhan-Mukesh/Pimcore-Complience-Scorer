{
    "name": "chauhan-mukesh/pimcore-market-readiness-shield",
    "description": "Market Readiness Shield — Compliance & Readiness Scorer for Pimcore Studio. Calculates live completeness scores for DataObjects against configurable Readiness Profiles.",
    "type": "symfony-bundle",
    "license": "MIT",
    "keywords": [
        "pimcore",
        "pimcore-bundle",
        "compliance",
        "readiness",
        "scoring",
        "pim",
        "pharma",
        "fmcg",
        "studio"
    ],
    "authors": [
        {
            "name": "Mukesh Chauhan",
            "homepage": "https://github.com/Chauhan-Mukesh",
            "role": "Developer"
        }
    ],
    "require": {
        "php": ">=8.2",
        "pimcore/pimcore": ">=2025.4 <2027.0",
        "symfony/framework-bundle": "^7.1",
        "symfony/messenger": "^7.1",
        "symfony/doctrine-messenger": "^7.1",
        "symfony/uid": "^7.1",
        "symfony/validator": "^7.1",
        "symfony/security-bundle": "^7.1",
        "symfony/rate-limiter": "^7.1",
        "doctrine/orm": "^3.2",
        "doctrine/dbal": "^4.0",
        "doctrine/doctrine-bundle": "^2.12",
        "doctrine/doctrine-migrations-bundle": "^3.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-symfony": "^2.0",
        "phpstan/phpstan-doctrine": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.60",
        "vimeo/psalm": "^5.26",
        "symfony/test-pack": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "CauhanMukesh\\PimcoreMarketReadinessShieldBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CauhanMukesh\\PimcoreMarketReadinessShieldBundle\\Tests\\": "src/Tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "extra": {
        "pimcore": {
            "bundles": [
                "CauhanMukesh\\PimcoreMarketReadinessShieldBundle\\PimcoreMarketReadinessShieldBundle"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
